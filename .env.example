# ── App EC2 — environment variables ──
NODE_ENV=production
PORT=3000

# Same ElastiCache instance Web EC2 points at — required for shared sessions.
REDIS_URL=redis://app-redis-cluster.xxxxxx.ng.0001.aps1.cache.amazonaws.com:6379

# Must be identical to Web EC2's SESSION_SECRET.
SESSION_SECRET=

# CORS allow-list — include your public domain (served via ALB) here.
# Not strictly needed if Web EC2 and App EC2 sit behind the same ALB/domain
# with path-based routing, but kept as defense-in-depth.
ALLOWED_ORIGINS=https://afl.acc.ltd,https://acc.ltd

# ── Azure AD / Office 365 SSO (OAuth handshake stays on App EC2 only) ──
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
REDIRECT_URI=https://your-domain.com/auth/callback
SUPER_ADMIN_EMAIL=

# ── AWS ──
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=axis-underwriting-documents
KMS_KEY_ID=

# ── Anthropic / OCR ──
ANTHROPIC_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_VISION_API_KEY=

# ── SIEM ──
SIEM_API_KEY=
SIEM_API_SECRET=
SIEM_ALLOWED_IPS=

# ── Build metadata (set by CI/CD, optional) ──
BUILD_DATE=
BUILD_NUMBER=
GIT_COMMIT=
USE_PARTITIONED_STRUCTURE=true
